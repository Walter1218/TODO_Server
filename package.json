{
  "name": "agent-todo-server",
  "version": "1.1.0-pre.2",
  "description": "TODO task management service for AI agents to reduce context inflation and task divergence",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "setup": "node scripts/setup.js",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "agent": "node start.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:coverage": "jest --runInBand --forceExit --detectOpenHandles --coverage",
    "patch:hermes": "node scripts/patch-hermes-scheduler.js",
    "sync:skills": "node scripts/sync_skills.js",
    "setup:hermes": "node scripts/setup_hermes_agents.js && node scripts/sync_skills.js",
    "start:agents": "node scripts/start_all.js",
    "pm2:start": "npx pm2 start ecosystem.config.js",
    "pm2:stop": "npx pm2 stop todo-server hermes-default hermes-ops hermes-coder",
    "pm2:restart": "npx pm2 restart todo-server hermes-default hermes-ops hermes-coder",
    "pm2:status": "npx pm2 status",
    "pm2:logs": "npx pm2 logs",
    "pm2:monit": "npx pm2 monit",
    "pm2:install-logrotate": "npx pm2 install pm2-logrotate && npx pm2 set pm2-logrotate:max_size 10M && npx pm2 set pm2-logrotate:retain 7 && npx pm2 set pm2-logrotate:compress true"
  },
  "postinstall": "node scripts/patch-hermes-scheduler.js",
  "keywords": [
    "todo",
    "task-management",
    "ai-agent",
    "context-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "pm2": "^7.0.0"
  }
}
